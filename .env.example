# Anthropic API key used for answer generation (and eval judging).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-placeholder

# Model used to draft/answer tickets. Defaults to Opus for quality; swap to
# claude-sonnet-5 or claude-haiku-4-5 if you want a cheaper per-ticket cost
# for this specific high-volume, low-complexity workload.
GENERATION_MODEL=claude-opus-4-8

# Model used by the eval harness to judge answer correctness (kept cheap/fast).
JUDGE_MODEL=claude-haiku-4-5

# Local embedding model (sentence-transformers), no API key required.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Where the persistent Chroma vector store lives.
CHROMA_DIR=./chroma_db

# Below this confidence (0-1), the ticket is escalated to a human instead of auto-resolved.
CONFIDENCE_THRESHOLD=0.72

# Assumed fully-loaded cost of a human agent handling one ticket, used for the cost-savings metric.
HUMAN_TICKET_COST_USD=8.0
